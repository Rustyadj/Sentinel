# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL with pgvector extension required
DATABASE_URL="postgresql://hermes:hermes@localhost:5432/hermesos"

# ── NextAuth ──────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
AUTH_SECRET="your-secret-here"

# Public URL of your deployment (no trailing slash)
AUTH_URL="https://srv1427612.hstgr.cloud"

# ── OAuth Providers (optional) ────────────────────────────────────────────────
# Google — https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# GitHub — https://github.com/settings/developers
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── Traefik / TLS ─────────────────────────────────────────────────────────────
# Your public domain — used for Traefik routing rules and TLS cert
DOMAIN=srv1427612.hstgr.cloud

# Email for Let's Encrypt certificate notifications
ACME_EMAIL=rustyadj@gmail.com

# ── VPS Control Plane ─────────────────────────────────────────────────────────
# Mark Sentinel as the primary UI served at the VPS root
SENTINEL_DEFAULT_UI=true

# Control-plane roles are database-backed workspace Owner/Admin assignments.

# Agent HTTP endpoints (internal Docker network)
HERMES_ENDPOINT=http://127.0.0.1:4860
HERMES_CLINT_ENDPOINT=http://127.0.0.1:4861
OPENCLAW_ENDPOINT=http://127.0.0.1:3001

# Model overrides (optional)
# HERMES_LISA_MODEL=claude-sonnet-4-6
# HERMES_CLINT_MODEL=claude-sonnet-4-6
# OPENCLAW_MODEL=claude-opus-4-8

# Directory for per-agent config files (CLAUDE.md, config.json, etc.)
AGENT_CONFIG_DIR=/opt/sentinel-os/agents

# Directory for agent log files (file-based fallback when docker logs unavailable)
AGENT_LOG_DIR=/opt/sentinel-os/logs

# ── AI Providers (per-user — set in Settings → API Keys, NOT here) ────────────
# Provider credentials are server-only in production.
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""
OPENROUTER_API_KEY=""
ALLOW_BROWSER_PROVIDER_KEYS=false
NEXT_PUBLIC_VOICE_PROVIDER=browser_stt
