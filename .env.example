# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL with pgvector extension required
DATABASE_URL="postgresql://hermes:hermes@localhost:5432/hermesos"

# ── NextAuth ──────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
AUTH_SECRET="your-secret-here"

# Public URL of your deployment (no trailing slash)
AUTH_URL="https://srv1427612.hstgr.cloud"

# ── Neural Engine (Phase E) ───────────────────────────────────────────────────
# Shared secret for POST /api/neural/degradation/sweep — this repo has no
# in-process scheduler, so an external cron (Vercel Cron, a GitHub Action, an
# ops script) must call it periodically with `Authorization: Bearer <value>`.
# Leave unset to disable the endpoint (it fails closed).
NEURAL_SWEEP_SECRET=""

# ── OAuth Providers (optional) ────────────────────────────────────────────────
# Google — https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# GitHub — https://github.com/settings/developers
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# Adaptive memory and MCP (server-only)
ACTIVE_MEMORY_MAX_TOKENS=1200
REFLECTION_COST_THRESHOLD=2
REFLECTION_RUNTIME_THRESHOLD_MS=120000
DELEGATION_MAX_RUNTIME_MS=3600000
DELEGATION_MAX_COST=25
MCP_MAX_BODY_BYTES=1000000
# Generate independently for each environment. Rotating it invalidates all MCP credentials.
MCP_CREDENTIAL_PEPPER=""

# Local stdio adapter only; do not expose the credential to a model or commit it.
SENTINEL_MCP_URL="http://127.0.0.1:3000/mcp"
SENTINEL_MCP_CREDENTIAL=""

# ── Traefik / TLS ─────────────────────────────────────────────────────────────
# Your public domain — used for Traefik routing rules and TLS cert
DOMAIN=srv1427612.hstgr.cloud

# Email for Let's Encrypt certificate notifications
ACME_EMAIL=rustyadj@gmail.com

# ── VPS Control Plane ─────────────────────────────────────────────────────────
# Mark Sentinel as the primary UI served at the VPS root
SENTINEL_DEFAULT_UI=true

# Control-plane roles are database-backed workspace Owner/Admin assignments.

# Agent HTTP endpoints (internal Docker network)
HERMES_ENDPOINT=http://127.0.0.1:4860
HERMES_CLINT_ENDPOINT=http://127.0.0.1:4861
OPENCLAW_ENDPOINT=http://127.0.0.1:3001

# Model overrides (optional)
# HERMES_LISA_MODEL=claude-sonnet-4-6
# HERMES_CLINT_MODEL=claude-sonnet-4-6
# OPENCLAW_MODEL=claude-opus-4-8

# Directory for per-agent config files (CLAUDE.md, config.json, etc.)
AGENT_CONFIG_DIR=/opt/sentinel-os/agents

# Directory for agent log files (file-based fallback when docker logs unavailable)
AGENT_LOG_DIR=/opt/sentinel-os/logs

# ── AI Providers (per-user — set in Settings → API Keys, NOT here) ────────────
# Provider credentials are server-only in production.
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""
OPENROUTER_API_KEY=""
ALLOW_BROWSER_PROVIDER_KEYS=false
NEXT_PUBLIC_VOICE_PROVIDER=browser_stt
